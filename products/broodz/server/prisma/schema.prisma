generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(100)
  slug      String   @unique @db.VarChar(100)
  icon      String?  @db.VarChar(50)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  talents Talent[]

  @@map("categories")
}

model User {
  id                Int       @id @default(autoincrement())
  email             String    @unique @db.VarChar(255)
  name              String?   @db.VarChar(255)
  magicToken        String?   @map("magic_token") @db.VarChar(255)
  magicTokenExpires DateTime? @map("magic_token_expires") @db.Timestamptz()
  jwtToken          String?   @map("jwt_token")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime  @default(now()) @map("updated_at") @db.Timestamptz()

  talents Talent[]

  @@map("users")
}

model Talent {
  id           Int     @id @default(autoincrement())
  userId       Int     @map("user_id")
  slug         String? @unique @db.VarChar(100)
  name         String  @db.VarChar(255)
  tagline      String? @db.VarChar(255)
  bio          String?
  categoryId   Int?    @map("category_id")
  location     String? @db.VarChar(255)
  profileImage String? @map("profile_image") @db.VarChar(500)
  coverImage   String? @map("cover_image") @db.VarChar(500)
  socialLinks  Json    @default("{}") @map("social_links")
  isPublished  Boolean @default(false) @map("is_published")
  isBeta       Boolean @default(false) @map("is_beta")
  theme        String  @default("earth") @db.VarChar(20)
  phone        String? @db.VarChar(50)
  email        String? @db.VarChar(255)
  whatsapp     String? @db.VarChar(50)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz()

  user      User       @relation(fields: [userId], references: [id])
  category  Category?  @relation(fields: [categoryId], references: [id])
  services  Service[]
  portfolio PortfolioItem[]
  products  Product[]
  enquiries Enquiry[]

  @@index([slug], map: "idx_talents_slug")
  @@index([categoryId], map: "idx_talents_category")
  @@index([isPublished], map: "idx_talents_published")
  @@map("talents")
}

model Service {
  id         Int      @id @default(autoincrement())
  talentId   Int      @map("talent_id")
  name       String   @db.VarChar(255)
  description String?
  price      Decimal? @db.Decimal(10, 2)
  priceLabel String?  @map("price_label") @db.VarChar(100)
  duration   String?  @db.VarChar(100)
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt  DateTime @default(now()) @map("updated_at") @db.Timestamptz()

  talent Talent @relation(fields: [talentId], references: [id], onDelete: Cascade)

  @@index([talentId], map: "idx_services_talent")
  @@map("services")
}

model PortfolioItem {
  id           Int      @id @default(autoincrement())
  talentId     Int      @map("talent_id")
  type         String   @default("image") @db.VarChar(20)
  url          String   @db.VarChar(500)
  thumbnailUrl String?  @map("thumbnail_url") @db.VarChar(500)
  title        String?  @db.VarChar(255)
  description  String?
  sortOrder    Int      @default(0) @map("sort_order")
  embedUrl     String?  @map("embed_url") @db.VarChar(500)
  platform     String?  @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  talent Talent @relation(fields: [talentId], references: [id], onDelete: Cascade)

  @@index([talentId], map: "idx_portfolio_talent")
  @@map("portfolio_items")
}

model Product {
  id         Int      @id @default(autoincrement())
  talentId   Int      @map("talent_id")
  name       String   @db.VarChar(255)
  description String?
  price      Decimal? @db.Decimal(10, 2)
  priceLabel String?  @map("price_label") @db.VarChar(100)
  imageUrl   String?  @map("image_url") @db.VarChar(500)
  inStock    Boolean  @default(true) @map("in_stock")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt  DateTime @default(now()) @map("updated_at") @db.Timestamptz()

  talent Talent @relation(fields: [talentId], references: [id], onDelete: Cascade)

  @@index([talentId], map: "idx_products_talent")
  @@map("products")
}

model Enquiry {
  id           Int      @id @default(autoincrement())
  talentId     Int      @map("talent_id")
  visitorName  String   @map("visitor_name") @db.VarChar(255)
  visitorEmail String   @map("visitor_email") @db.VarChar(255)
  visitorPhone String?  @map("visitor_phone") @db.VarChar(50)
  message      String
  status       String   @default("new") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz()

  talent Talent @relation(fields: [talentId], references: [id], onDelete: Cascade)

  @@index([talentId], map: "idx_enquiries_talent")
  @@map("enquiries")
}
