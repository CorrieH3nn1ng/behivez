      "id": "d1000001-0001-0001-0001-000000000006",
      "name": "Extract Text",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [1120, 400]
    },
    {
      "parameters": {
        "functionCode": "const apiResponse = items[0].json;\nconst formData = $node['Parse Form Data'].json;\n\nconst text = apiResponse.text || apiResponse.paper_text || '';\nconst wordCount = apiResponse.word_count || text.split(/\\\\s+/).filter(w => w.length > 0).length;\nconst pageCount = apiResponse.page_count || 1;\n\nconst safeSubject = (formData.subject || '').replace(/'/g, \"''\");\nconst safeAssessmentType = (formData.assessment_type || '').replace(/'/g, \"''\");\nconst safeFilename = (formData.filename || '').replace(/'/g, \"''\");\nconst safeText = text.replace(/'/g, \"''\");\n\nreturn [{\n  json: {\n    email: formData.email,\n    subject: safeSubject,\n    assessment_type: safeAssessmentType,\n    filename: safeFilename,\n    paper_text: safeText,\n    word_count: wordCount,\n    page_count: pageCount\n  }\n}];"
      },
      "id": "d1000001-0001-0001-0001-000000000007",
      "name": "Parse Extraction",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [1340, 400]
    },
