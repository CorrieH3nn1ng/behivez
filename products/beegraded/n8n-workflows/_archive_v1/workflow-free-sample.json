        "query": "={{ \"INSERT INTO papers (filename, subject, assessment_type, paper_text, word_count, page_count) VALUES ('\" + $json.filename + \"', '\" + $json.subject + \"', '\" + $json.assessment_type + \"', '\" + $json.paper_text + \"', \" + $json.word_count + \", \" + $json.page_count + \") RETURNING id;\" }}",
        "additionalFields": {}
