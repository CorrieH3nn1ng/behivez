    {
      "id": "d1000001-0001-0001-0001-000000000002",
      "name": "Query Eval Status",
      "type": "n8n-nodes-base.postgres",
      "position": [
        460,
        100
      ],
      "parameters": {
        "query": "={{ 'SELECT id, paper_id, mode, draft_or_final, overall_score, report_html IS NOT NULL AS has_report FROM evaluations WHERE paper_id = ' + (parseInt($json.query.id) || 0) + ' OR id = ' + (parseInt($json.query.id) || 0) + ' ORDER BY id DESC LIMIT 1' }}",
        "operation": "executeQuery",
        "additionalFields": {}
      },
      "credentials": {
        "postgres": {
          "id": "RwGl9RX2FyWfj4I7",
          "name": "BeeGraded Postgres"
        }
      },
      "typeVersion": 1,
      "alwaysOutputData": true
    },
    {
      "id": "d1000001-0001-0001-0001-000000000003",
      "name": "Format Status Response",
      "type": "n8n-nodes-base.function",
      "position": [
        680,
        200
      ],
      "parameters": {
        "functionCode": "const row = items[0].json;\nif (!row || !row.id) {\n  return [{ json: { status: 'processing', message: 'Evaluation in progress' } }];\n}\nreturn [{\n  json: {\n    id: row.id,\n    paper_id: row.paper_id,\n    mode: row.mode,\n    status: row.has_report ? 'complete' : 'processing',\n    overall_score: row.overall_score,\n    has_report: row.has_report\n  }\n}];"
      },
      "typeVersion": 1
    },
    {
      "id": "d1000001-0001-0001-0001-000000000004",
      "name": "Respond Status",
      "type": "n8n-nodes-base.respondToWebhook",
      "position": [
        900,
        200
      ],
      "parameters": {
        "options": {},
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify($json) }}"
      },
      "typeVersion": 1
    },
    {
      "id": "d1000001-0001-0001-0002-000000000001",
