      "id": "d1000001-0001-0001-0001-000000000001",
      "name": "Webhook Free Sample",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "bg-free-sample"
    },
    {
      "parameters": {
        "functionCode": "// Parse form data from webhook\nconst body = items[0].json.body || items[0].json;\n\nlet email = (body.email || '').toLowerCase().trim();\n\n// Normalize gmail: strip +suffix and dots\nif (email.includes('@gmail.com')) {\n  const [local, domain] = email.split('@');\n  const cleaned = local.split('+')[0].replace(/\\./g, '');\n  email = cleaned + '@' + domain;\n}\n\nconst subject = body.subject || 'Unknown';\nconst assessmentType = body.assessment_type || 'exam';\n\n// Get binary file key\nconst binaryKey = Object.keys(items[0].binary || {})[0] || 'file';\nconst filename = (items[0].binary && items[0].binary[binaryKey]) ? items[0].binary[binaryKey].fileName || 'upload.pdf' : 'upload.pdf';\n\nreturn [{\n  json: {\n    email,\n    subject,\n    assessment_type: assessmentType,\n    filename,\n    binaryKey\n  },\n  binary: items[0].binary\n}];"
      },
      "id": "d1000001-0001-0001-0001-000000000002",
      "name": "Parse Form Data",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [460, 300]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "={{ \"SELECT id FROM free_samples WHERE email = '\" + $json.email.replace(/'/g, \"''\") + \"' LIMIT 1;\" }}",
        "additionalFields": {}
      },
      "id": "d1000001-0001-0001-0001-000000000003",
      "name": "Check Email Uniqueness",
